#!/bin/bash
# Alias para o script transcrever.py
# Executa usando o Python do ambiente virtual (.venv)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_PY="$SCRIPT_DIR/.venv/bin/python3"

if [ -f "$VENV_PY" ]; then
    exec "$VENV_PY" "$SCRIPT_DIR/transcrever.py" "$@"
else
    echo "Erro: Ambiente virtual não encontrado"
    exit 1
fi
